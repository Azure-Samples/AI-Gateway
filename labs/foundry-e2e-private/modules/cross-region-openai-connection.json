    "finalApimApiName": "[if(not(empty(parameters('apimApiName'))), parameters('apimApiName'), format('azure-openai-{0}', parameters('location')))]",
    "finalConnectionName": "[if(not(empty(parameters('connectionName'))), parameters('connectionName'), format('apim-gateway-{0}', parameters('location')))]",
    "staticModels": [
      {
        "name": "[parameters('modelName')]",
        "properties": {
          "model": {
            "name": "[parameters('modelName')]",
            "version": "[parameters('modelVersion')]",
            "format": "OpenAI"
          }
        }
      }
    ]
  },
  "resources": [
    {
      "type": "Microsoft.CognitiveServices/accounts",
      "apiVersion": "2025-04-01-preview",
      "name": "[parameters('openAIName')]",
      "location": "[parameters('location')]",
      "kind": "OpenAI",
      "sku": {
