      "apiVersion": "2024-05-01",
      "name": "[format('{0}/{1}', parameters('apimName'), variables('finalApimApiName'))]",
      "properties": {
        "displayName": "[format('Azure OpenAI {0}', parameters('location'))]",
        "path": "[format('openai-{0}', parameters('location'))]",
        "protocols": [
