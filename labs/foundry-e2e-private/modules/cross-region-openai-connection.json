    },
    {
      "type": "Microsoft.CognitiveServices/accounts/projects/connections",
      "apiVersion": "2025-04-01-preview",
      "name": "[format('{0}/{1}/{2}', parameters('accountName'), parameters('projectName'), variables('finalConnectionName'))]",
      "properties": {
        "category": "ApiManagement",
        "target": "[format('{0}/{1}', reference(resourceId('Microsoft.ApiManagement/service', parameters('apimName')), '2024-05-01').gatewayUrl, reference(resourceId('Microsoft.ApiManagement/service/apis', parameters('apimName'), variables('finalApimApiName')), '2024-05-01').path)]",
        "authType": "ApiKey",
        "isSharedToAll": true,
        "credentials": {
