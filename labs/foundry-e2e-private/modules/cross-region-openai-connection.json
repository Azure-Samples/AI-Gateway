      "properties": {
        "subnet": {
          "id": "[extensionResourceId(format('/subscriptions/{0}/resourceGroups/{1}', subscription().subscriptionId, parameters('vnetResourceGroupName')), 'Microsoft.Network/virtualNetworks/subnets', parameters('vnetName'), parameters('peSubnetName'))]"
        },
        "privateLinkServiceConnections": [
          {
            "name": "[format('{0}-private-link-service-connection', parameters('openAIName'))]",
            "properties": {
              "privateLinkServiceId": "[resourceId('Microsoft.CognitiveServices/accounts', parameters('openAIName'))]",
              "groupIds": [
                "account"
              ]
            }
          }
        ]
      },
      "dependsOn": [
        "[resourceId('Microsoft.CognitiveServices/accounts', parameters('openAIName'))]"
      ]
    },
    {
      "condition": "[variables('createPrivateEndpoint')]",
      "type": "Microsoft.Network/privateEndpoints/privateDnsZoneGroups",
      "apiVersion": "2024-05-01",
      "name": "[format('{0}/{1}', format('{0}-private-endpoint', parameters('openAIName')), format('{0}-dns-group', parameters('openAIName')))]",
      "properties": {
        "privateDnsZoneConfigs": [
          {
            "name": "openai-dns-config",
            "properties": {
              "privateDnsZoneId": "[resourceId('Microsoft.Network/privateDnsZones', 'privatelink.openai.azure.com')]"
            }
          }
        ]
      },
      "dependsOn": [
