      "type": "Microsoft.ApiManagement/service/apis/policies",
      "apiVersion": "2024-05-01",
      "name": "[format('{0}/{1}/{2}', parameters('apimName'), variables('finalApimApiName'), 'policy')]",
      "properties": {
        "format": "xml",
        "value": "<policies><inbound><base /><authentication-managed-identity resource=\"https://cognitiveservices.azure.com/\" /></inbound><backend><base /></backend><outbound><base /></outbound><on-error><base /></on-error></policies>"
      },
      "dependsOn": [
        "[resourceId('Microsoft.ApiManagement/service/apis', parameters('apimName'), variables('finalApimApiName'))]"
      ]
    },
    {
      "condition": "[variables('createPrivateEndpoint')]",
      "type": "Microsoft.Network/privateEndpoints",
      "apiVersion": "2024-05-01",
