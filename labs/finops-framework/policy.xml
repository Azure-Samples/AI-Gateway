<policies>
    <inbound>
        <base />
        <set-backend-service backend-id="{backend-id}" />
        <choose>
            {product-token-limits}
        </choose>
        <azure-openai-emit-token-metric namespace="aiusage">
            <dimension name="Product" value="@(context.Product.Id)" />
        </azure-openai-emit-token-metric>
    </inbound>
    <backend>
        <base />
    </backend>
    <outbound>
        <base />
    </outbound>
    <on-error>
        <base />
    </on-error>
</policies>
