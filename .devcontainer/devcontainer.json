{
	"name": "AI Gateway Dev Container",
	"image": "mcr.microsoft.com/devcontainers/python:3.13",
	"hostRequirements": {
	  "cpus": 2
	},
	"features": {
		"ghcr.io/devcontainers/features/azure-cli:1": {
			"installBicep": true,
			"version": "latest"
		}
	},
	"waitFor": "onCreateCommand",
    "updateContentCommand": "curl -LsSf https://astral.sh/uv/install.sh | sh && $HOME/.local/bin/uv sync",
    "postCreateCommand": "",
	"customizations": {
	  "codespaces": {
		"openFiles": []
	  },
	  "vscode": {
		"extensions": [
		  "ms-toolsai.jupyter",
		  "ms-python.python",
		  "ms-azuretools.vscode-bicep"
		]
	  }
	}
}
